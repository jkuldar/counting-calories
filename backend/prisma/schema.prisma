generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String   // Already hashed with bcrypt (empty for OAuth users)
  emailVerified       Boolean  @default(false)
  verificationCode    String?  @unique
  refreshToken        String?  // Should be hashed/encrypted
  lastActivityAt      DateTime @default(now())
  
  // OAuth fields
  oauthProvider       String?  // 'google', 'github', etc.
  oauthId             String?  // Provider's user ID
  
  // Password reset
  resetToken          String?  @unique
  resetTokenExpiry    DateTime?
  
  // Two-Factor Authentication
  twoFactorSecret     String?  // TOTP secret
  twoFactorEnabled    Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relations
  healthProfile       HealthProfile?
  weightHistory       WeightHistory[]
  privacySettings     PrivacySettings?
  activityEntries     ActivityEntry[]
  habitLogs           HabitLog[]
  mealPlans           MealPlan[]
  mealPlanPreferences MealPlanPreferences?
  nutritionalLogs     NutritionalLog[]
  shoppingLists       ShoppingList[]
  
  @@map("users")
}

model HealthProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Consent
  consentGiven          Boolean  @default(false)
  consentTimestamp      DateTime?
  
  // Demographics (encrypted)
  age                   Int?
  gender                String?  // 'male', 'female', 'prefer_not_to_say'
  
  // Physical (normalized to kg, cm)
  heightCm              Float?
  currentWeightKg       Float?
  targetWeightKg        Float?
  
  // Lifestyle
  activityLevel         String?  // 'sedentary', 'light', 'moderate', 'active', 'very_active'
  sleepHoursPerDay      Float?
  stressLevel           String?  // 'low', 'moderate', 'high'
  
  // Dietary preferences
  dietaryPreferences    String[] // 'vegetarian', 'vegan', 'pescatarian', 'keto', etc.
  allergies             String[] // List of allergies
  restrictions          String[] // List of dietary restrictions
  
  // Goals
  primaryGoal           String?  // 'lose_weight', 'gain_weight', 'maintain', 'build_muscle', 'improve_fitness'
  targetDate            DateTime?
  weeklyActivityGoal    Int?     // Times per week
  
  // Fitness assessment
  fitnessLevel          String?  // 'beginner', 'intermediate', 'advanced'
  exerciseTypes         String[] // 'cardio', 'strength', 'flexibility', 'sports'
  sessionDuration       String?  // '15-30min', '30-60min', '60+min'
  exerciseEnvironment   String?  // 'home', 'gym', 'outdoors', 'mixed'
  exerciseTimeOfDay     String?  // 'morning', 'afternoon', 'evening', 'no_preference'
  enduranceMinutes      Int?     // Can run/walk for X minutes
  pushUpsCount          Int?     // Max push-ups
  squatsCount           Int?     // Max squats
  occupationType        String?  // 'desk', 'physical', 'mixed', 'student', 'retired'
  medicalConditions     String[] // List of conditions (encrypted)
  medications           String[] // List of medications (encrypted)

  // Derived metrics
  bmi                   Float?
  bmiClass              String?
  wellnessScore         Int?
  progressPercent       Float?
  nextMilestonePercent  Float?
  activityStreakDays    Int?
  habitStreakDays       Int?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("health_profiles")
}

model WeightHistory {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  weightKg              Float    // Normalized to kg
  recordedAt            DateTime @default(now())
  note                  String?
  
  @@unique([userId, recordedAt])
  @@map("weight_history")
}

model ActivityEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String?
  durationMin Int?
  intensity   String?
  calories    Float?
  steps       Int?
  loggedAt    DateTime @default(now())
  note        String?

  @@unique([userId, loggedAt])
  @@map("activity_entries")
}

model HabitLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitType  String
  loggedDate DateTime @default(now())
  note       String?

  @@unique([userId, habitType, loggedDate])
  @@map("habit_logs")
}

model PrivacySettings {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Data sharing preferences
  shareWithAI           Boolean  @default(true)
  shareAnonymousData    Boolean  @default(false)
  allowDataExport       Boolean  @default(true)
  
  // What data to include in AI prompts
  includeWeight         Boolean  @default(true)
  includeActivity       Boolean  @default(true)
  includeDietary        Boolean  @default(true)
  includeGoals          Boolean  @default(true)
  includeMedical        Boolean  @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("privacy_settings")
}

model AIInsight {
  id                    String   @id @default(uuid())
  userId                String
  
  // Prompt and response
  prompt                String   @db.Text
  response              String   @db.Text
  
  // Context hash (to identify similar contexts)
  contextHash           String
  
  // Priority tagging
  priority              String   // 'high', 'medium', 'low'
  
  // Validation flags
  isValid               Boolean  @default(true)
  violatesRestrictions  Boolean  @default(false)
  validationNotes       String?  @db.Text
  
  // Metadata
  model                 String   // 'gpt-3.5-turbo', etc.
  tokensUsed            Int?
  responseTimeMs        Int?
  
  createdAt             DateTime @default(now())
  expiresAt             DateTime? // For cache invalidation
  
  @@index([userId, contextHash])
  @@index([userId, createdAt])
  @@map("ai_insights")
}

// ============================================================
// MEAL PLANNING & NUTRITION MODELS (Project 2)
// ============================================================

model Recipe {
  id              String   @id @default(uuid())
  title           String
  cuisine         String
  meal            String   // 'breakfast', 'lunch', 'dinner', 'snack'
  servings        Int
  summary         String   @db.Text
  time            Int      // preparation time in minutes
  difficultyLevel String   @map("difficulty_level") // 'easy', 'medium', 'hard'
  dietaryTags     String[] @map("dietary_tags")
  source          String   // 'rag-database', 'ai-generated', 'user-created'
  img             String?

  // Vector embedding for RAG (stored as JSON array string)
  embedding       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  ingredients     RecipeIngredient[]
  preparation     RecipeStep[]
  mealPlanMeals   MealPlanMeal[]

  @@map("recipes")
}

model Ingredient {
  id          String  @id @default(uuid())
  label       String  @unique
  unit        String  // 'gram' or 'ml'
  quantity    Float   // reference quantity (typically 100)

  // Nutritional info per reference quantity
  calories    Float   // kcal
  carbs       Float   // grams
  protein     Float   // grams
  fats        Float   // grams

  // Vector embedding for RAG (stored as JSON array string)
  embedding   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float      // in standardized unit (g or ml)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id            String @id @default(uuid())
  recipeId      String
  recipe        Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber    Int
  step          String          // step title
  description   String @db.Text // step instructions
  ingredientIds String[]        // ingredient IDs used in this step

  @@unique([recipeId, stepNumber])
  @@map("recipe_steps")
}

model MealPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  duration    String   // 'daily', 'weekly'
  startDate   DateTime
  endDate     DateTime
  version     Int      @default(1)
  isActive    Boolean  @default(true)

  // Snapshot of user preferences at creation time (for regeneration)
  preferencesSnapshot Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  meals         MealPlanMeal[]
  shoppingLists ShoppingList[]

  @@index([userId, isActive])
  @@index([userId, createdAt])
  @@map("meal_plans")
}

model MealPlanMeal {
  id          String   @id @default(uuid())
  mealPlanId  String
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  recipeId    String?
  recipe      Recipe?  @relation(fields: [recipeId], references: [id])

  date        DateTime // specific date for this meal
  mealType    String   // 'breakfast', 'lunch', 'dinner', 'snack'
  mealTime    String?  // ISO 8601 time, e.g. "08:00"
  sortOrder   Int      @default(0)

  // Custom meal fields (when not linked to a recipe)
  customName     String?
  customCalories Float?
  customProtein  Float?
  customCarbs    Float?
  customFats     Float?

  // Calculated nutritional info
  calories    Float?
  protein     Float?
  carbs       Float?
  fats        Float?
  servings    Int      @default(1)

  isManual    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mealPlanId, date])
  @@map("meal_plan_meals")
}

model ShoppingList {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlanId String?
  mealPlan   MealPlan? @relation(fields: [mealPlanId], references: [id])

  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items      ShoppingListItem[]

  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String       @id @default(uuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  ingredientId   String?
  name           String  // ingredient display name
  quantity       Float   // in standardized unit
  unit           String  // 'g', 'ml'
  category       String  // 'dairy', 'produce', 'grains', 'protein', 'condiments', 'spices', 'oils', 'beverages', 'other'
  isChecked      Boolean @default(false)
  isRemoved      Boolean @default(false)

  @@map("shopping_list_items")
}

model NutritionalLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date       DateTime
  mealType   String?  // 'breakfast', 'lunch', 'dinner', 'snack'

  // Nutritional values
  calories   Float
  protein    Float
  carbs      Float
  fats       Float

  // Source tracking
  recipeId   String?
  mealPlanId String?
  isManual   Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@index([userId, date])
  @@map("nutritional_logs")
}

model MealPlanPreferences {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  timezone            String   @default("UTC")
  mealsPerDay         Int      @default(3)
  snacksPerDay        Int      @default(0)

  // Preferred meal times (HH:MM format)
  breakfastTime       String?  // e.g. "08:00"
  lunchTime           String?  // e.g. "12:30"
  dinnerTime          String?  // e.g. "19:00"
  snackTime           String?  // e.g. "15:00"

  // Cuisine & ingredient preferences
  cuisinePreferences  String[]
  dislikedIngredients String[]

  // Calorie/macro targets (can override auto-calculated values)
  calorieTarget       Float?
  proteinTarget       Float?
  carbsTarget         Float?
  fatsTarget          Float?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("meal_plan_preferences")
}
